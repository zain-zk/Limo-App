DATABASE_URL="postgresql://limo:limo_dev_password@localhost:5432/limo_app?schema=public"
PORT=3001
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Public site URL (used for Stripe success/cancel redirects)
FRONTEND_URL=http://localhost:5173

# Stripe (Phase 1 — Checkout after quote)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Currency for Checkout amounts (CAD recommended for High5 Limo)
STRIPE_CURRENCY=cad

# Optional SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ADMIN_PHONE=
